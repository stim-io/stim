{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "stim",
  "version": "0.1.0",
  "identifier": "io.stim.app",
  "build": {
    "beforeDevCommand": "pnpm --dir ../renderer dev --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "pnpm --dir ../renderer build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../renderer/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "stim",
        "width": 1200,
        "height": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
