{
  "name": "stim",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "cargo run -p stim-dev-cli -- start",
    "dev:renderer": "cargo run -p stim-dev-cli -- start renderer",
    "dev:tauri": "cargo run -p stim-dev-cli -- start tauri",
    "build:renderer": "pnpm --dir apps/renderer build",
    "typecheck:renderer": "pnpm --dir apps/renderer typecheck"
  }
}
